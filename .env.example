# MySQL（本机程序目录：D:\Environment\MySQL）
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=root
DB_NAME=nuxt_interaction
DB_CONNECTION_LIMIT=10

# JWT
JWT_SECRET=nuxt-interaction-jwt-secret-key-2025

# Sentry DSN 存于 system_configs.sentry_dsn，环境变量仅作备用
# NUXT_PUBLIC_SENTRY_DSN=

# 上传 Source Map 时使用（可选）
SENTRY_AUTH_TOKEN=
